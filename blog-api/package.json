{
  "name": "blog-api",
  "version": "1.0.0",
  "description": "REST API for The Margin Blog — Node.js + Prisma + SQLite",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force && tsx prisma/seed.ts"
  },
  "dependencies": {
    "@libsql/client": "latest",
    "@prisma/adapter-libsql": "latest",
    "@prisma/client": "latest",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "slugify": "^1.6.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "latest",
    "prisma": "latest",
    "tsx": "^4.15.7",
    "typescript": "^5.5.3"
  }
}
